PORT=8181
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/whatsapp-webhook
SESSION_SECRET=your-secret-key-change-this

# Single-session mode: set to your MongoDB user _id to lock WhatsApp to one session
# Leave empty for multi-tenant mode (all users can create sessions)
DEFAULT_USER_ID=

# Log verbosity: ERROR | WARN | INFO | DEBUG
# Default is WARN to reduce file writes and disk IOPS
LOG_LEVEL=warn
